# See https://help.github.com/articles/ignoring-files/ for more about ignoring files.

# dependencies
/node_modules
/.pnp
.pnp.js
.yarn/install-state.gz

# testing
/coverage

# next.js
/.next/
/out/

# production
/build

# misc
.DS_Store
*.pem

# debug
npm-debug.log*
yarn-debug.log*
yarn-error.log*

# local env files
.env*.local

# vercel
.vercel

# typescript
*.tsbuildinfo
next-env.d.ts

# ---- Anti-script guard ----
# Diagnostic / forensic scripts (never commit these)
read-*.js
extract-*.js
find-*.js
print-*.js
recover-*.js
search-*.js
search-backups.js
format-*.js
analyze-*.js
dump-index-*.js
list-all-*.js
check-frontend.js

# Generated output blobs (never commit these)
extracted-*.js
extracted-*.txt
recovered_*.js
recovered_pages/
diff*.txt
*.err
